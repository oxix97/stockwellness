# ================================================================
# StockWellness Production 환경변수 템플릿
# 경로: /home/chan/stockwellness/deploy/.env.prod.example
#
# 사용법: cp .env.prod.example .env.prod  → 실제 값으로 수정
# .env.prod 는 .gitignore에 반드시 추가!
# ================================================================

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=stockwellness
POSTGRES_USER=swuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_256BIT_BASE64_SECRET

# ── GHCR 이미지 태그 (배포 스크립트가 자동 갱신) ──────────────────
REGISTRY=ghcr.io
REPO_OWNER=your-github-username
IMAGE_API=ghcr.io/your-github-username/stockwellness-api
IMAGE_BATCH=ghcr.io/your-github-username/stockwellness-batch
API_TAG_BLUE=latest
API_TAG_GREEN=latest
BATCH_TAG=latest

# ── n8n (Tailscale 내부망으로만 접근) ──────────────────────────
# 외부 노출 불필요 — Tailscale IP로 직접 접근
# 예) http://100.x.x.x:5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_N8N_PASSWORD
N8N_ENCRYPTION_KEY=CHANGE_ME_32CHAR_KEY

# ── GitHub Actions SSH 배포용 (서버에서 설정) ──────────────────
# DEPLOY_USER: SSH 접속 유저명 (예: ubuntu, svd)
# DEPLOY_HOST: Tailscale에서 할당된 서버 IP 또는 MagicDNS 호스트명
#   확인 방법: 서버에서 `tailscale ip -4` 실행
# GitHub Secrets에 등록:
#   TS_OAUTH_CLIENT_ID    — Tailscale OAuth App Client ID
#   TS_OAUTH_SECRET       — Tailscale OAuth App Secret
#   DEPLOY_SSH_KEY        — SSH 개인키 (서버 authorized_keys에 공개키 등록 필요)
#   DEPLOY_USER           — SSH 유저
#   DEPLOY_HOST           — Tailscale IP 또는 MagicDNS
