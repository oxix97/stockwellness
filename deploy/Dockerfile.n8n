# ================================================================
# n8n 커스텀 이미지 — docker-cli + curl 포함
#
# n8n Execute Command 노드에서 deploy 스크립트를 실행하려면
# n8n 컨테이너 내부에 docker CLI가 있어야 합니다.
# ================================================================
FROM n8nio/n8n:latest

USER root
RUN apk add --no-cache docker-cli curl

USER node
